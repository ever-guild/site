{
  "name": "@ever-guild/site",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --max-warnings 0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "acceptance:test": "npm run build && playwright test && node scripts/check-visual-snapshots.mjs",
    "acceptance:update": "npm run build && playwright test --update-snapshots && node scripts/check-visual-snapshots.mjs",
    "lighthouse": "npm run build && lhci autorun",
    "vt:check": "node .github/actions/virustotal-url-check/check-url.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0"
  },
  "overrides": {
    "@babel/core": "^7.29.6",
    "js-yaml": "^4.2.0",
    "tmp": "^0.2.6",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "baseline-browser-mapping": "^2.10.43",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  }
}

{
  "name": "@ever-guild/site",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --max-warnings 0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "acceptance:test": "npm run build && playwright test && node scripts/check-visual-snapshots.mjs",
    "acceptance:update": "npm run build && playwright test --update-snapshots && node scripts/check-visual-snapshots.mjs",
    "lighthouse": "npm run build && lhci autorun",
    "vt:check": "node .github/actions/virustotal-url-check/check-url.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/fiber": "^9.6.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "three": "^0.184.0"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "baseline-browser-mapping": "^2.10.32",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  }
}
